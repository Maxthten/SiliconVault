{
  "name": "siliconvault",
  "productName": "SiliconVault",
  "version": "1.4.0",
  "description": "电子元器件库存管理系统",
  "main": "./out/main/index.js",
  "author": "Maxton Niu",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:phase1": "node scripts/run-phase1-integration.cjs",
    "test:quality": "node scripts/run-quality-tests.cjs",
    "test:unicode-build": "node scripts/test-unicode-build.cjs",
    "test:integration": "node scripts/run-phase1-integration.cjs && node scripts/run-quality-tests.cjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --config electron-builder.yml --dir",
    "build:win": "npm run build && electron-builder --config electron-builder.yml --win",
    "build:mac": "npm run build && electron-builder --config electron-builder.yml --mac",
    "build:linux": "npm run build && electron-builder --config electron-builder.yml --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@vicons/ionicons5": "^0.13.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "echarts": "^6.0.0",
    "electron-store": "^8.1.0",
    "naive-ui": "^2.43.2",
    "papaparse": "^5.5.3",
    "vfonts": "^0.0.3",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
